# =============================================================================
# MaterialScope .env.example
# Copy this file to ".env" for local development.
# Do not commit real API keys, tokens, personal email addresses, or machine paths.
# =============================================================================

# Primary app:
#   python -m dash_app.server
#   http://127.0.0.1:8050

# Optional backend/library settings. Leave blank unless you are testing a
# local API setup that requires explicit configuration.
MATERIALSCOPE_LIBRARY_CLOUD_URL=
MATERIALSCOPE_LIBRARY_CLOUD_ENABLED=false
MATERIALSCOPE_LIBRARY_ALLOW_FULL_PROVIDER_SYNC=false

# Keep preview modules disabled for portfolio/demo runs unless you are
# explicitly testing experimental features.
MATERIALSCOPE_ENABLE_PREVIEW_MODULES=false

# Optional literature metadata provider settings.
# Use a local .env only; never commit real values.
MATERIALSCOPE_OPENALEX_EMAIL=
MATERIALSCOPE_OPENALEX_API_KEY=

# Optional local storage roots. Prefer leaving these blank so the app uses
# repository-local defaults during development.
MATERIALSCOPE_LIBRARY_HOSTED_ROOT=
MATERIALSCOPE_LIBRARY_MIRROR_ROOT=
